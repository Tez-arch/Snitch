<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover, user-scalable=no">
<title>Midnight — Private Gallery</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,450;9..144,600&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#0a0a0f;
    --bg-2:#111119;
    --surface:#16161f;
    --surface-2:#1d1d29;
    --line: rgba(245,244,250,0.08);
    --accent:#7C6FFF;
    --accent-2:#6450F0;
    --text:#F4F3FA;
    --muted:#8D8AA3;
    --danger:#FF7A7A;
    --radius: 14px;
  }
  *{box-sizing:border-box; -webkit-tap-highlight-color: transparent;}
  html,body{
    margin:0; padding:0; height:100%;
    background:var(--bg);
    color:var(--text);
    font-family:'Inter', sans-serif;
    overflow:hidden;
    overscroll-behavior:none;
  }
  #app{position:fixed; inset:0; overflow:hidden;}

  /* ---------------- shared ---------------- */
  .mono{font-family:'IBM Plex Mono', monospace; letter-spacing:0.02em;}
  .display{font-family:'Fraunces', serif;}
  button{font-family:inherit; cursor:pointer; -webkit-appearance:none; appearance:none;}

  /* ---------------- PIN GATE ---------------- */
  #gate{
    position:absolute; inset:0;
    display:flex; flex-direction:column; align-items:center; justify-content:center;
    background:
      radial-gradient(90% 60% at 50% 0%, rgba(124,111,255,0.14), transparent 60%),
      radial-gradient(70% 50% at 50% 100%, rgba(100,80,240,0.10), transparent 60%),
      var(--bg);
    transition: opacity 0.6s ease, filter 0.6s ease;
    z-index:20;
    padding:6vh 24px;
  }
  #gate.leaving{ opacity:0; filter: blur(6px); pointer-events:none; }

  .gate-eyebrow{
    font-size:11px; text-transform:uppercase; letter-spacing:0.22em; color:var(--muted); margin-bottom:18px;
  }
  .gate-title{
    font-size:28px; font-weight:450; margin:0 0 6px; text-align:center; letter-spacing:0.01em;
  }
  .gate-sub{
    font-size:13px; color:var(--muted); margin:0 0 44px; text-align:center;
  }

  /* Aperture iris — the signature element */
  .iris-wrap{ position:relative; width:168px; height:168px; margin-bottom:40px; }
  .iris-svg{ width:100%; height:100%; transform:rotate(0deg); transition: transform 1.1s cubic-bezier(.2,.9,.25,1); }
  .iris-blade{
    transform-origin:84px 84px;
    fill:var(--surface-2);
    stroke:var(--line);
    stroke-width:1;
    transition: transform 0.7s cubic-bezier(.2,.9,.25,1), fill 0.4s ease;
  }
  .iris-ring{ fill:none; stroke:var(--line); stroke-width:1; }
  .iris-center-dot{
    position:absolute; top:50%; left:50%; transform:translate(-50%,-50%);
    display:flex; gap:7px;
  }
  .iris-dot{
    width:7px; height:7px; border-radius:50%;
    background: rgba(245,244,250,0.14);
    transition: background 0.25s ease, transform 0.25s ease;
  }
  .iris-dot.filled{ background: var(--accent); transform:scale(1.15); }
  .iris-dot.error{ background: var(--danger); }

  #gate.opening .iris-blade{ transform: scale(2.4) rotate(50deg); opacity:0; }
  #gate.shake .iris-wrap{ animation: shake 0.4s; }
  @keyframes shake{
    10%,90%{ transform:translateX(-2px);} 20%,80%{ transform:translateX(4px);}
    30%,50%,70%{ transform:translateX(-7px);} 40%,60%{ transform:translateX(7px);}
  }

  .keypad{
    display:grid; grid-template-columns:repeat(3, 64px); gap:14px;
    margin-bottom:20px;
  }
  .key{
    width:64px; height:64px; border-radius:50%;
    border:1px solid var(--line);
    background:var(--surface);
    color:var(--text);
    font-size:20px; font-weight:500;
    display:flex; align-items:center; justify-content:center;
    transition: background 0.15s ease, border-color 0.15s ease, transform 0.1s ease;
  }
  .key:active{ transform:scale(0.92); background:var(--surface-2); border-color: rgba(124,111,255,0.4); }
  .key.ghost{ background:transparent; border-color:transparent; color:var(--muted); font-size:13px; }

  .gate-error{
    height:18px; font-size:12px; color:var(--danger); margin-top:4px; opacity:0; transition:opacity 0.2s ease;
  }
  .gate-error.show{ opacity:1; }

  /* ---------------- GALLERY ---------------- */
  #gallery-screen{
    position:absolute; inset:0; overflow-y:auto; -webkit-overflow-scrolling:touch;
    opacity:0; pointer-events:none; transition: opacity 0.6s ease 0.15s;
  }
  #gallery-screen.active{ opacity:1; pointer-events:auto; }

  header.topbar{
    position:sticky; top:0; z-index:5;
    display:flex; align-items:baseline; justify-content:space-between;
    padding:22px 20px 14px;
    background: linear-gradient(to bottom, rgba(10,10,15,0.96) 60%, rgba(10,10,15,0));
    backdrop-filter: blur(6px);
  }
  .topbar h1{ font-size:19px; font-weight:450; margin:0; letter-spacing:0.01em; }
  .topbar .count{ font-size:12px; color:var(--muted); }

  .masonry{
    column-count:2; column-gap:10px;
    padding:0 12px 60px;
  }
  @media (min-width:640px){ .masonry{ column-count:3; } }
  @media (min-width:960px){ .masonry{ column-count:4; padding:0 20px 60px; } }
  @media (min-width:1300px){ .masonry{ column-count:5; } }

  .tile{
    break-inside:avoid; margin-bottom:10px;
    border-radius:10px; overflow:hidden;
    position:relative; background:var(--surface);
    opacity:0; transform:translateY(10px);
    animation: rise 0.5s ease forwards;
  }
  @keyframes rise{ to{ opacity:1; transform:none; } }
  .tile img{
    width:100%; display:block;
    transition: transform 0.5s cubic-bezier(.2,.8,.2,1), filter 0.4s ease;
    background:var(--surface-2);
  }
  .tile:active img{ transform:scale(0.97); }
  .tile .tile-date{
    position:absolute; left:8px; bottom:7px;
    font-size:10px; color:rgba(244,243,250,0.85);
    background:rgba(10,10,15,0.45); backdrop-filter:blur(3px);
    padding:3px 7px; border-radius:20px;
    opacity:0; transition:opacity 0.2s ease;
  }
  @media (hover:hover){ .tile:hover .tile-date{ opacity:1; } .tile:hover img{ transform:scale(1.03); } }

  /* ---------------- VIEWER ---------------- */
  #viewer{
    position:absolute; inset:0; background:#000; z-index:30;
    opacity:0; pointer-events:none; transition: opacity 0.35s ease;
  }
  #viewer.active{ opacity:1; pointer-events:auto; }
  .viewer-track{ position:absolute; inset:0; touch-action:none; }
  .viewer-slide{
    position:absolute; inset:0;
    display:flex; align-items:center; justify-content:center;
    overflow:hidden;
  }
  .viewer-slide img{
    max-width:100%; max-height:100%; touch-action:none;
    will-change: transform;
    user-select:none; -webkit-user-drag:none;
  }

  .viewer-topbar{
    position:absolute; top:0; left:0; right:0; z-index:2;
    display:flex; justify-content:space-between; align-items:center;
    padding:18px 16px; padding-top:calc(18px + env(safe-area-inset-top));
    background:linear-gradient(to bottom, rgba(0,0,0,0.55), transparent);
  }
  .icon-btn{
    width:38px; height:38px; border-radius:50%;
    border:1px solid rgba(245,244,250,0.15);
    background:rgba(20,20,28,0.55); backdrop-filter:blur(6px);
    color:var(--text); display:flex; align-items:center; justify-content:center;
  }
  .icon-btn svg{ width:18px; height:18px; }

  .viewer-bottombar{
    position:absolute; bottom:0; left:0; right:0; z-index:2;
    padding:16px; padding-bottom:calc(16px + env(safe-area-inset-bottom));
    display:flex; flex-direction:column; gap:12px;
    background:linear-gradient(to top, rgba(0,0,0,0.6), transparent);
  }
  .meta-panel{
    max-height:0; overflow:hidden; opacity:0;
    transition: max-height 0.3s ease, opacity 0.3s ease;
  }
  .meta-panel.show{ max-height:120px; opacity:1; }
  .meta-row{
    display:flex; justify-content:space-between; font-size:12px;
    padding:7px 0; border-bottom:1px solid rgba(245,244,250,0.08);
  }
  .meta-row:last-child{ border-bottom:none; }
  .meta-label{ color:var(--muted); }
  .meta-value{ color:var(--text); }

  .viewer-actions{ display:flex; gap:10px; align-items:center; }
  .pill-btn{
    flex:1; height:44px; border-radius:22px; border:none;
    background:var(--surface); color:var(--text);
    display:flex; align-items:center; justify-content:center; gap:8px;
    font-size:13px; font-weight:500;
    border:1px solid var(--line);
  }
  .pill-btn.primary{
    background: linear-gradient(135deg, var(--accent), var(--accent-2));
    border:none; color:#fff;
  }
  .pill-btn svg{ width:16px; height:16px; }
  .pill-btn:active{ transform:scale(0.97); }

  .dots-strip{
    display:flex; gap:4px; justify-content:center; padding-bottom:4px;
  }
  .dots-strip span{
    width:5px; height:5px; border-radius:50%; background:rgba(245,244,250,0.2);
  }
  .dots-strip span.on{ background:var(--accent); width:14px; border-radius:3px; transition:all 0.25s ease; }

  ::-webkit-scrollbar{ width:0; height:0; }
</style>
</head>
<body>
<div id="app">

  <!-- ============ PIN GATE ============ -->
  <div id="gate">
    <div class="gate-eyebrow">Midnight</div>
    <h1 class="gate-title display">Enter access code</h1>
    <p class="gate-sub">Six digits unlock this collection</p>

    <div class="iris-wrap">
      <svg class="iris-svg" viewBox="0 0 168 168">
        <circle class="iris-ring" cx="84" cy="84" r="82"></circle>
        <g id="blades"></g>
      </svg>
      <div class="iris-center-dot" id="dots"></div>
    </div>

    <div class="gate-error mono" id="gateError">Incorrect code</div>

    <div class="keypad" id="keypad"></div>
  </div>

  <!-- ============ GALLERY ============ -->
  <div id="gallery-screen">
    <header class="topbar">
      <h1 class="display">Gallery Stream</h1>
      <span class="count mono" id="photoCount"></span>
    </header>
    <div class="masonry" id="masonry"></div>
  </div>

  <!-- ============ VIEWER ============ -->
  <div id="viewer">
    <div class="viewer-topbar">
      <button class="icon-btn" id="viewerClose" aria-label="Close">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
      <button class="icon-btn" id="viewerInfo" aria-label="Info">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 11v5M12 8v.01"/></svg>
      </button>
    </div>
    <div class="viewer-track" id="viewerTrack"></div>
    <div class="viewer-bottombar">
      <div class="meta-panel mono" id="metaPanel">
        <div class="meta-row"><span class="meta-label">Captured</span><span class="meta-value" id="metaDate">—</span></div>
        <div class="meta-row"><span class="meta-label">Resolution</span><span class="meta-value" id="metaRes">—</span></div>
        <div class="meta-row"><span class="meta-label">File</span><span class="meta-value" id="metaFile">—</span></div>
      </div>
      <div class="dots-strip" id="dotsStrip"></div>
      <div class="viewer-actions">
        <button class="pill-btn" id="metaToggleBtn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 11v5M12 8v.01"/></svg>
          Details
        </button>
        <a class="pill-btn primary" id="downloadBtn" download>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3v12m0 0l-4-4m4 4l4-4M4 19h16"/></svg>
          Download
        </a>
      </div>
    </div>
  </div>

</div>

<script>
(function(){
  "use strict";
  const CODE = "170420";

  /* ---------- Build aperture blades ---------- */
  const bladesGroup = document.getElementById('blades');
  const bladeCount = 8;
  for(let i=0;i<bladeCount;i++){
    const angle = (360/bladeCount)*i;
    const blade = document.createElementNS("http://www.w3.org/2000/svg","path");
    blade.setAttribute("class","iris-blade");
    blade.setAttribute("d","M84,84 L84,6 A78,78 0 0 1 133,26 Z");
    blade.setAttribute("transform", `rotate(${angle} 84 84)`);
    blade.style.transitionDelay = (i*0.02)+"s";
    bladesGroup.appendChild(blade);
  }

  /* ---------- PIN dots ---------- */
  const dotsEl = document.getElementById('dots');
  for(let i=0;i<6;i++){
    const d = document.createElement('div');
    d.className='iris-dot';
    dotsEl.appendChild(d);
  }
  const dotEls = [...dotsEl.children];

  /* ---------- Keypad ---------- */
  const keypad = document.getElementById('keypad');
  const layout = ["1","2","3","4","5","6","7","8","9","ghost","0","back"];
  let entered = "";

  function renderKeypad(){
    keypad.innerHTML = "";
    layout.forEach(k=>{
      const btn = document.createElement('button');
      if(k==="ghost"){ btn.className="key ghost"; btn.disabled=true; }
      else if(k==="back"){
        btn.className="key ghost"; btn.textContent="⌫";
        btn.addEventListener('click', ()=> updateEntry(entered.slice(0,-1)));
      } else {
        btn.className="key"; btn.textContent=k;
        btn.addEventListener('click', ()=> updateEntry(entered+k));
      }
      keypad.appendChild(btn);
    });
  }
  renderKeypad();

  const gate = document.getElementById('gate');
  const gateError = document.getElementById('gateError');

  function updateEntry(val){
    if(val.length>6) return;
    entered = val;
    dotEls.forEach((d,i)=>{
      d.classList.toggle('filled', i<entered.length);
      d.classList.remove('error');
    });
    gateError.classList.remove('show');
    if(entered.length===6){
      setTimeout(()=>{
        if(entered===CODE) unlock();
        else fail();
      }, 120);
    }
  }

  function fail(){
    gateError.classList.add('show');
    dotEls.forEach(d=> d.classList.add('error'));
    gate.classList.add('shake');
    setTimeout(()=>{
      gate.classList.remove('shake');
      entered = "";
      dotEls.forEach(d=> d.classList.remove('filled','error'));
    }, 420);
  }

  function unlock(){
    gate.classList.add('opening');
    setTimeout(()=> gate.classList.add('leaving'), 550);
    setTimeout(()=>{
      gate.style.display='none';
      document.getElementById('gallery-screen').classList.add('active');
    }, 1150);
  }

  document.addEventListener('keydown', (e)=>{
    if(gate.style.display==='none') return;
    if(/^[0-9]$/.test(e.key)) updateEntry(entered+e.key);
    if(e.key==='Backspace') updateEntry(entered.slice(0,-1));
  });

  /* ==================================================================
     PHOTO DATA
     In a real deployment these would point at your own hosted images;
     here we use varied-aspect placeholder photography to demonstrate
     the masonry + viewer behaviour end to end.
  ================================================================== */
  const raw = [
    {id:1015, ar:[4,5], date:"2026-06-28"}, {id:1016, ar:[3,2], date:"2026-06-24"},
    {id:1018, ar:[1,1], date:"2026-06-19"}, {id:1019, ar:[9,16],date:"2026-06-15"},
    {id:1020, ar:[3,4], date:"2026-06-09"}, {id:1021, ar:[16,9],date:"2026-06-02"},
    {id:1024, ar:[4,5], date:"2026-05-27"}, {id:1027, ar:[3,2], date:"2026-05-20"},
    {id:1031, ar:[1,1], date:"2026-05-14"}, {id:1033, ar:[9,16],date:"2026-05-08"},
    {id:1035, ar:[3,4], date:"2026-04-30"}, {id:1039, ar:[16,9],date:"2026-04-22"},
    {id:1041, ar:[4,5], date:"2026-04-17"}, {id:1043, ar:[3,2], date:"2026-04-10"},
    {id:1044, ar:[1,1], date:"2026-04-03"}, {id:1047, ar:[9,16],date:"2026-03-27"},
    {id:1050, ar:[3,4], date:"2026-03-19"}, {id:1053, ar:[16,9],date:"2026-03-12"},
    {id:1056, ar:[4,5], date:"2026-03-05"}, {id:1059, ar:[3,2], date:"2026-02-25"},
    {id:1062, ar:[1,1], date:"2026-02-17"}, {id:1063, ar:[9,16],date:"2026-02-09"},
    {id:1067, ar:[3,4], date:"2026-02-02"}, {id:1071, ar:[16,9],date:"2026-01-24"}
  ];

  function dims(ar, base){
    const [w,h] = ar;
    const scale = base / Math.max(w,h);
    return { w: Math.round(w*scale), h: Math.round(h*scale) };
  }

  const photos = raw
    .map(p=>{
      const thumb = dims(p.ar, 700);
      const full  = dims(p.ar, 2400);
      return {
        ...p,
        thumbUrl: `https://picsum.photos/id/${p.id}/${thumb.w}/${thumb.h}`,
        fullUrl:  `https://picsum.photos/id/${p.id}/${full.w}/${full.h}`,
        fullW: full.w, fullH: full.h,
        filename: `IMG_${p.id}_${p.date.replace(/-/g,'')}.jpg`
      };
    })
    .sort((a,b)=> new Date(b.date) - new Date(a.date));

  document.getElementById('photoCount').textContent = photos.length + ' photos';

  /* ---------- Render masonry ---------- */
  const masonry = document.getElementById('masonry');
  photos.forEach((p, idx)=>{
    const tile = document.createElement('div');
    tile.className = 'tile';
    tile.style.animationDelay = (idx*0.03)+'s';
    tile.innerHTML = `
      <img src="${p.thumbUrl}" loading="lazy" width="${p.ar[0]}" height="${p.ar[1]}" alt="Photo captured ${p.date}">
      <div class="tile-date mono">${formatDate(p.date)}</div>
    `;
    tile.addEventListener('click', ()=> openViewer(idx));
    masonry.appendChild(tile);
  });

  function formatDate(iso){
    const d = new Date(iso+"T12:00:00");
    return d.toLocaleDateString('en-US', {month:'short', day:'numeric', year:'numeric'});
  }

  /* ==================================================================
     VIEWER — swipe between photos, pinch/double-tap to zoom, pan
  ================================================================== */
  const viewer = document.getElementById('viewer');
  const track = document.getElementById('viewerTrack');
  const metaPanel = document.getElementById('metaPanel');
  const dotsStrip = document.getElementById('dotsStrip');
  let current = 0;
  let slides = [];

  function buildDotsStrip(){
    dotsStrip.innerHTML = "";
    photos.forEach((_,i)=>{
      const s = document.createElement('span');
      dotsStrip.appendChild(s);
    });
  }
  buildDotsStrip();

  function openViewer(idx){
    current = idx;
    viewer.classList.add('active');
    renderSlide();
  }

  function closeViewer(){
    viewer.classList.remove('active');
    metaPanel.classList.remove('show');
  }
  document.getElementById('viewerClose').addEventListener('click', closeViewer);

  function updateDots(){
    [...dotsStrip.children].forEach((s,i)=> s.classList.toggle('on', i===current));
  }

  function updateMeta(){
    const p = photos[current];
    document.getElementById('metaDate').textContent = new Date(p.date+"T12:00:00")
      .toLocaleDateString('en-US',{month:'long', day:'numeric', year:'numeric'});
    document.getElementById('metaRes').textContent = `${p.fullW} × ${p.fullH}`;
    document.getElementById('metaFile').textContent = p.filename;
    document.getElementById('downloadBtn').href = p.fullUrl;
    document.getElementById('downloadBtn').setAttribute('download', p.filename);
  }

  document.getElementById('metaToggleBtn').addEventListener('click', ()=>{
    metaPanel.classList.toggle('show');
  });
  document.getElementById('viewerInfo').addEventListener('click', ()=>{
    metaPanel.classList.toggle('show');
  });

  /* ---- Slide + gesture engine ---- */
  let scale=1, panX=0, panY=0, lastTouchDist=0, lastTap=0;
  let dragging=false, dragStartX=0, dragStartY=0, startPanX=0, startPanY=0;
  let swipeStartX=0, swipeStartY=0, swiping=false;

  function renderSlide(){
    track.innerHTML = "";
    const p = photos[current];
    const slide = document.createElement('div');
    slide.className = 'viewer-slide';
    const img = document.createElement('img');
    img.src = p.fullUrl;
    img.alt = "Full view";
    slide.appendChild(img);
    track.appendChild(slide);
    scale=1; panX=0; panY=0;
    applyTransform(img);
    updateDots();
    updateMeta();
    attachGestures(slide, img);
  }

  function applyTransform(img){
    img.style.transform = `translate(${panX}px, ${panY}px) scale(${scale})`;
  }

  function attachGestures(slide, img){
    slide.addEventListener('touchstart', (e)=>{
      if(e.touches.length===2){
        lastTouchDist = touchDist(e.touches);
        swiping=false; dragging=false;
      } else if(e.touches.length===1){
        const now = Date.now();
        if(now - lastTap < 280){
          scale = scale>1 ? 1 : 2.4; panX=0; panY=0; applyTransform(img);
        }
        lastTap = now;
        if(scale>1){
          dragging=true;
          dragStartX = e.touches[0].clientX; dragStartY = e.touches[0].clientY;
          startPanX = panX; startPanY = panY;
        } else {
          swiping=true;
          swipeStartX = e.touches[0].clientX; swipeStartY = e.touches[0].clientY;
        }
      }
    }, {passive:true});

    slide.addEventListener('touchmove', (e)=>{
      if(e.touches.length===2){
        const dist = touchDist(e.touches);
        const delta = dist - lastTouchDist;
        scale = Math.min(4, Math.max(1, scale + delta*0.01));
        lastTouchDist = dist;
        applyTransform(img);
      } else if(dragging){
        panX = startPanX + (e.touches[0].clientX - dragStartX);
        panY = startPanY + (e.touches[0].clientY - dragStartY);
        applyTransform(img);
      } else if(swiping){
        const dx = e.touches[0].clientX - swipeStartX;
        slide.style.transform = `translateX(${dx}px)`;
        slide.style.transition='none';
      }
    }, {passive:true});

    slide.addEventListener('touchend', (e)=>{
      if(swiping){
        const dx = (e.changedTouches[0].clientX - swipeStartX);
        const dy = (e.changedTouches[0].clientY - swipeStartY);
        slide.style.transition='transform 0.3s ease';
        if(Math.abs(dx) > 70 && Math.abs(dx) > Math.abs(dy)){
          if(dx < 0 && current < photos.length-1){ current++; renderSlide(); return; }
          if(dx > 0 && current > 0){ current--; renderSlide(); return; }
        }
        if(Math.abs(dy) > 120 && Math.abs(dy) > Math.abs(dx)){
          closeViewer(); return;
        }
        slide.style.transform = 'translateX(0)';
      }
      dragging=false; swiping=false;
      if(scale<1.02){ scale=1; panX=0; panY=0; applyTransform(img); }
    });
  }

  function touchDist(touches){
    const dx = touches[0].clientX - touches[1].clientX;
    const dy = touches[0].clientY - touches[1].clientY;
    return Math.hypot(dx,dy);
  }

  /* Desktop: click edges to navigate, wheel? keep simple with arrow keys */
  document.addEventListener('keydown', (e)=>{
    if(!viewer.classList.contains('active')) return;
    if(e.key==='ArrowRight' && current<photos.length-1){ current++; renderSlide(); }
    if(e.key==='ArrowLeft' && current>0){ current--; renderSlide(); }
    if(e.key==='Escape') closeViewer();
  });

})();
</script>
</body>
</html>
